STDMATH_EXPORT stdmath_{name} stdmath_{name}_linear_to_srgb_accurate(stdmath_{name} color);
STDMATH_EXPORT stdmath_{name} stdmath_{name}_gamma(stdmath_{name} color, float gamma);
